{
  "name": "alacarte",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Use workspace tests: client/server\"",
    "lint": "eslint .",
    "format": "prettier -w .",
    "prepare": "node -e \"if(!process.env.CI) { try { require('husky').install() } catch (e) { process.exit(0) } }\"",
    "dev:server": "npm run dev --prefix server --inspect",
    "dev:client": "npm run dev --prefix client -- --mode development",
    "dev:netlify": "netlify dev",
    "dev:local": "concurrently \"npm run dev:server\" \"npm run dev --prefix client\""
  },
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "type": "module",
  "dependencies": {
    "vite": "^5.4.10"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.2",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "axios": "^1.7.7",
    "baseline-browser-mapping": "^2.10.7",
    "body-parser": "^1.20.3",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "eslint": "^9.14.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "express": "^4.21.1",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "prettier": "^3.3.3",
    "serverless-http": "^3.2.0",
    "typescript-eslint": "^8.50.0"
  }
}
